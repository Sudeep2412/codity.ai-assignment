{
  "name": "codity-job-scheduler",
  "version": "1.0.0",
  "description": "Production-inspired distributed job scheduling platform",
  "private": true,
  "workspaces": [
    "server",
    "worker",
    "client"
  ],
  "scripts": {
    "dev:server": "npm run dev --workspace=server",
    "dev:worker": "npm run dev --workspace=worker",
    "dev:client": "npm run dev --workspace=client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "migrate": "npm run migrate --workspace=server",
    "migrate:rollback": "npm run migrate:rollback --workspace=server",
    "seed": "npm run seed --workspace=server",
    "test": "npm run test --workspace=server && npm run test --workspace=worker",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
